{
  "expo": {
    "name": "Digital Carbon Footprint Score",
    "slug": "digital-carbon-footprint-score",
    "version": "1.0.0",
    "scheme": "carbonscore",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8FAF7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sasmazt90.digitalcarbonfootprintscore",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Digital Carbon Footprint Score uses foreground location to estimate mobility patterns and encourage lower-carbon travel habits.",
        "NSMotionUsageDescription": "Digital Carbon Footprint Score uses motion activity to estimate steps and calmer movement patterns in your daily carbon score."
      }
    },
    "android": {
      "package": "com.sasmazt90.digitalcarbonfootprintscore",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F8FAF7"
      },
      "permissions": [
        "POST_NOTIFICATIONS",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACTIVITY_RECOGNITION"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#89D2C6",
          "defaultChannel": "carbon-coach"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "94f11e50-30e9-42c3-bb5f-01f0600a9038"
      }
    },
    "owner": "sasmazt90"
  }
}
