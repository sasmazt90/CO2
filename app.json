{
  "expo": {
    "name": "Digital Carbon Footprint Score",
    "slug": "digital-carbon-footprint-score",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8FAF7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sasmazt90.digitalcarbonfootprintscore"
    },
    "android": {
      "package": "com.sasmazt90.digitalcarbonfootprintscore",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F8FAF7"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#89D2C6",
          "defaultChannel": "carbon-coach"
        }
      ]
    ]
  }
}
